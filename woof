        local DropdownBottom = Instance.new("Frame")
        DropdownBottom.Name = "DropdownBottom"
        DropdownBottom.Parent = DropdownModule
        DropdownBottom.BackgroundColor3 = MainColor
        DropdownBottom.BorderSizePixel = 0
        DropdownBottom.ClipsDescendants = true
        DropdownBottom.Position = UDim2.new(0, 0, 0, 32)
        DropdownBottom.Size = UDim2.new(0, 312, 0, 0)
        DropdownBottom.Visible = false
        DropdownBottom.ZIndex = 10

        local DropdownBottomC = Instance.new("UICorner")
        DropdownBottomC.CornerRadius = UDim.new(0, 6)
        DropdownBottomC.Name = "DropdownBottomC"
        DropdownBottomC.Parent = DropdownBottom

        local DropdownBottomL = Instance.new("UIListLayout")
        DropdownBottomL.Name = "DropdownBottomL"
        DropdownBottomL.Parent = DropdownBottom
        DropdownBottomL.HorizontalAlignment = Enum.HorizontalAlignment.Center
        DropdownBottomL.SortOrder = Enum.SortOrder.LayoutOrder
        DropdownBottomL.Padding = UDim.new(0, 6)

        local DropdownBottomP = Instance.new("UIPadding")
        DropdownBottomP.Name = "DropdownBottomP"
        DropdownBottomP.Parent = DropdownBottom
        DropdownBottomP.PaddingTop = UDim.new(0, 6)

        local open = false
        local scrollConn = nil

        DropdownBottomL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            if not open then return end
            DropdownBottom.Size = UDim2.new(0, 312, 0, DropdownBottomL.AbsoluteContentSize.Y + 12)
        end)

        local function setAllVisible()
            for _, child in ipairs(DropdownBottom:GetChildren()) do
                if child:IsA("TextButton") then
                    child.Visible = true
                end
            end
        end

        local function searchDropdown(txt)
            for _, child in ipairs(DropdownBottom:GetChildren()) do
                if child:IsA("TextButton") then
                    if txt == "" then
                        child.Visible = true
                    else
                        child.Visible = child.Name:lower():sub(1, #txt) == txt:lower()
                    end
                end
            end
        end

        local function ToggleDropVis()
            open = not open
            if open then
                local absPos = DropdownModule.AbsolutePosition
                local absSize = DropdownModule.AbsoluteSize
                DropdownBottom.Parent = dogent
                DropdownBottom.Position = UDim2.fromOffset(absPos.X, absPos.Y + absSize.Y)
                DropdownBottom.Size = UDim2.new(0, 312, 0, DropdownBottomL.AbsoluteContentSize.Y + 12)
                DropdownBottom.Visible = true
                DropdownBottom.ZIndex = 100
                setAllVisible()

                local scrollFrame = parent
                while scrollFrame and not scrollFrame:IsA("ScrollingFrame") do
                    scrollFrame = scrollFrame.Parent
                end
                if scrollFrame then
                    scrollConn = scrollFrame:GetPropertyChangedSignal("CanvasPosition"):Connect(function()
                        if open then
                            ToggleDropVis()
                        end
                    end)
                end
            else
                if scrollConn then
                    scrollConn:Disconnect()
                    scrollConn = nil
                end
                DropdownBottom.Visible = false
                DropdownBottom.Parent = DropdownModule
                DropdownBottom.Position = UDim2.new(0, 0, 0, 32)
                DropdownBottom.Size = UDim2.new(0, 312, 0, 0)
            end
            DropdownOpen.Text = (open and "-" or "+")
        end

        DropdownOpen.MouseButton1Click:Connect(ToggleDropVis)

        DropdownText.Focused:Connect(function()
            if not open then
                ToggleDropVis()
            end
        end)

        DropdownText:GetPropertyChangedSignal("Text"):Connect(function()
            if open then
                searchDropdown(DropdownText.Text)
            end
        end)

        services.UserInputService.InputBegan:Connect(function(input, gpe)
            if gpe then return end
            if open and input.UserInputType == Enum.UserInputType.MouseButton1 then
                local mousePos = Vector2.new(input.Position.X, input.Position.Y)
                local moduleBounds = DropdownModule.AbsolutePosition
                local moduleSize = DropdownModule.AbsoluteSize
                local bottomBounds = DropdownBottom.AbsolutePosition
                local bottomSize = DropdownBottom.AbsoluteSize
                local inModule = mousePos.X >= moduleBounds.X and mousePos.X <= moduleBounds.X + moduleSize.X
                    and mousePos.Y >= moduleBounds.Y and mousePos.Y <= moduleBounds.Y + moduleSize.Y
                local inBottom = mousePos.X >= bottomBounds.X and mousePos.X <= bottomBounds.X + bottomSize.X
                    and mousePos.Y >= bottomBounds.Y and mousePos.Y <= bottomBounds.Y + bottomSize.Y
                if not inModule and not inBottom then
                    ToggleDropVis()
                end
            end
        end)

        local dropdownObj = {
            State = library.flags[flag],
            SetOptions = function(self, opts)
                self:ClearOptions()
                for _, opt in ipairs(opts) do
                    self:AddOption(opt)
                end
            end,
            ClearOptions = function(self)
                for _, child in ipairs(DropdownBottom:GetChildren()) do
                    if child:IsA("TextButton") then
                        child:Destroy()
                    end
                end
            end,
            AddOption = function(self, opt)
                local Option = Instance.new("TextButton")
                local OptionC = Instance.new("UICorner")
                Option.Name = tostring(opt)
                Option.Parent = DropdownBottom
                Option.BackgroundColor3 = SecondaryColor
                Option.BorderSizePixel = 0
                Option.Size = UDim2.new(0, 300, 0, 28)
                Option.AutoButtonColor = false
                Option.Font = Enum.Font.GothamSemibold
                Option.Text = tostring(opt)
                Option.TextColor3 = TextColor        
                Option.TextSize = 14.000
                OptionC.CornerRadius = UDim.new(0, 6)
                OptionC.Name = "OptionCorner"
                OptionC.Parent = Option

                Option.MouseButton1Click:Connect(function()
                    DropdownText.PlaceholderText = tostring(opt)
                    DropdownText.Text = ""
                    library.flags[flag] = opt
                    dropdownObj.State = opt
                    if open then
                        ToggleDropVis()
                    end
                    callback(opt)
                end)
            end,
            RemoveOption = function(self, opt)
                local btn = DropdownBottom:FindFirstChild(tostring(opt))
                if btn then
                    btn:Destroy()
                end
            end
        }

        dropdownObj:SetOptions(options)
        return dropdownObj
    end

