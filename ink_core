                ListScroll.Name = "Scroll"
                ListScroll.Parent = DropdownList
                ListScroll.Active = true
                ListScroll.BackgroundTransparency = 1
                ListScroll.BorderSizePixel = 0
                ListScroll.Size = UDim2.new(1, 0, 1, 0)
                ListScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
                ListScroll.ScrollBarThickness = 3
                ListScroll.ZIndex = 10

                ListLayout.Parent = ListScroll
                ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
                ListLayout.Padding = UDim.new(0, 2)

                local Opened = false
                local OptionBtns = {}

                local function RefreshOptions()
                    for _, btn in pairs(OptionBtns) do
                        btn:Destroy()
                    end
                    OptionBtns = {}

                    for i, option in pairs(options) do
                        local OptionBtn = Instance.new("TextButton")
                        OptionBtn.Name = option
                        OptionBtn.Parent = ListScroll
                        OptionBtn.BackgroundColor3 = Themes[Library.CurrentTheme].Secondary
                        OptionBtn.Size = UDim2.new(1, 0, 0, 28)
                        OptionBtn.AutoButtonColor = false
                        OptionBtn.Font = Enum.Font.Gotham
                        OptionBtn.Text = option
                        OptionBtn.TextColor3 = Themes[Library.CurrentTheme].Text
                        OptionBtn.TextSize = 14
                        OptionBtn.ZIndex = 10

                        local OptionCorner = Instance.new("UICorner")
                        OptionCorner.CornerRadius = UDim.new(0, 4)
                        OptionCorner.Parent = OptionBtn

                        OptionBtn.MouseEnter:Connect(function()
                            TweenService:Create(OptionBtn, TweenInfo.new(0.2), {BackgroundColor3 = PresetColor}):Play()
                            OptionBtn.TextColor3 = Color3.fromRGB(255,255,255)
                        end)

                        OptionBtn.MouseLeave:Connect(function()
                            TweenService:Create(OptionBtn, TweenInfo.new(0.2), {BackgroundColor3 = Themes[Library.CurrentTheme].Secondary}):Play()
                            OptionBtn.TextColor3 = Themes[Library.CurrentTheme].Text
                        end)

                        OptionBtn.MouseButton1Click:Connect(function()
                            Library.flags[flag] = option
                            DropdownDisplay.Text = option
                            Opened = false
                            DropdownIcon.Text = "▼"
                            DropdownList.Visible = false
                            DropdownFrame:TweenSize(UDim2.new(1, 0, 0, 45), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true)
                            if callback then
                                pcall(callback, option)
                            end
                        end)

                        table.insert(OptionBtns, OptionBtn)
                    end

                    ListScroll.CanvasSize = UDim2.new(0, 0, 0, ListLayout.AbsoluteContentSize.Y)
                    local listHeight = math.min(#options * 30 + 10, 150)
                    DropdownList.Size = UDim2.new(1, -30, 0, listHeight)
                end

                RefreshOptions()

                DropdownBtn.MouseButton1Click:Connect(function()
                    Opened = not Opened
                    if Opened then
                        DropdownIcon.Text = "▲"
                        DropdownList.Visible = true
                        DropdownFrame:TweenSize(UDim2.new(1, 0, 0, 45 + DropdownList.Size.Y.Offset + 15), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true)
                    else
                        DropdownIcon.Text = "▼"
                        DropdownFrame:TweenSize(UDim2.new(1, 0, 0, 45), Enum.EasingDirection.Out, Enum.EasingStyle.Quad, 0.2, true)
                        wait(0.2)
                        DropdownList.Visible = false
                    end
                    UpdateCanvas()
                end)

                UpdateCanvas()

                return {
                    AddOption = function(self, option)
                        table.insert(options, option)
                        RefreshOptions()
                    end,
                    RemoveOption = function(self, option)
                        local idx = table.find(options, option)
                        if idx then
                            table.remove(options, idx)
                            RefreshOptions()
                        end
                    end,
                    SetOptions = function(self, newOptions)
                        options = newOptions
                        RefreshOptions()
                        if not table.find(options, Library.flags[flag]) and #options > 0 then
                            Library.flags[flag] = options[1]
                            DropdownDisplay.Text = options[1]
                        end
                    end,
                    GetSelected = function()
                        return Library.flags[flag]
                    end
                }
            end

