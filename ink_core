                        BindDisplay.Text = CurrentKey
                        BindDisplay.TextColor3 = PresetColor
                    else
                        BindDisplay.Text = CurrentKey
                        BindDisplay.TextColor3 = PresetColor
                    end
                    Listening = false
                end)

                UserInputService.InputBegan:Connect(function(Input, GameProcessed)
                    if not GameProcessed and Input.KeyCode.Name == CurrentKey and not Listening then
                        if callback then
