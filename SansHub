		currentTab = {button = configTabButton, frame = configTabObj.frame, highlight = configTabButton:FindFirstChild("Frame")} -- highlight 是那个小条
		currentTab.highlight.Visible = true
		currentTab.frame.Visible = true
		currentTab.frame.Position = UDim2.new(-1, 0, 0, 0)
		smoothTween(currentTab.frame, {Position = UDim2.new(0, 0, 0, 0)}, 0.2)
	end
end)

    refreshUIScale()
    smoothTween(mainFrame, {Position = UDim2.new(0.5, -scale(175), 0.5, -scale(125))}, 0.5)

    return tabs
end

return SansHubLib