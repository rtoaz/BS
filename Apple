                Fill.Name = "Fill"
                Fill.Parent = Track
                Fill.BackgroundColor3 = iOSColors.Primary
                Fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
                Fill.BorderSizePixel = 0

                local FillCorner = Instance.new("UICorner")
                FillCorner.CornerRadius = UDim.new(1, 0)
                FillCorner.Parent = Fill

                local Thumb = Instance.new("Frame")
                Thumb.Name = "Thumb"
                Thumb.Parent = Track
                Thumb.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                Thumb.Position = UDim2.new((default - min) / (max - min), -8, 0.5, -8)
                Thumb.Size = UDim2.new(0, 16, 0, 16)
                Thumb.BorderSizePixel = 0

                local ThumbCorner = Instance.new("UICorner")
                ThumbCorner.CornerRadius = UDim.new(1, 0)
                ThumbCorner.Parent = Thumb

                local function updateValue(input)
                    local pos = math.clamp((input.Position.X - Track.AbsolutePosition.X) / Track.AbsoluteSize.X, 0, 1)
                    local value = min + (max - min) * pos
                    if not precise then value = math.floor(value) end
                    library.flags[flag] = value
                    ValueLabel.Text = tostring(value)
                    Fill.Size = UDim2.new(pos, 0, 1, 0)
                    Thumb.Position = UDim2.new(pos, -8, 0.5, -8)
                    callback(value)
                end

                local dragging = false

                Track.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                        updateValue(input)
                    end
                end)

                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = false
                    end
                end)

                UserInputService.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        updateValue(input)
                    end
                end)

                return {
                    SetValue = function(self, value)
                        local clamped = math.clamp(value, min, max)
                        local pos = (clamped - min) / (max - min)
                        library.flags[flag] = clamped
                        ValueLabel.Text = tostring(clamped)
                        Fill.Size = UDim2.new(pos, 0, 1, 0)
                        Thumb.Position = UDim2.new(pos, -8, 0.5, -8)
                        callback(clamped)
                    end
                }
            end

            function section.Dropdown(section, text, flag, options, callback)
                callback = callback or function() end
                options = options or {}
                library.flags[flag] = nil

                local DropdownFrame = Instance.new("Frame")
                DropdownFrame.Name = text .. "_Dropdown"
                DropdownFrame.Parent = Objs
                DropdownFrame.BackgroundColor3 = iOSColors.Surface
                DropdownFrame.BorderSizePixel = 0
                DropdownFrame.Size = UDim2.new(1, 0, 0, 44)
                DropdownFrame.ClipsDescendants = true

                local DropdownCorner = Instance.new("UICorner")
                DropdownCorner.CornerRadius = UDim.new(0, 10)
                DropdownCorner.Parent = DropdownFrame

                local DropdownText = Instance.new("TextLabel")
                DropdownText.Parent = DropdownFrame
                DropdownText.BackgroundTransparency = 1
                DropdownText.Position = UDim2.new(0, 15, 0, 0)
                DropdownText.Size = UDim2.new(1, -50, 0, 44)
                DropdownText.Font = Enum.Font.GothamSemibold
                DropdownText.Text = text
                DropdownText.TextColor3 = Color3.fromRGB(255, 255, 255)
                DropdownText.TextSize = 14
                DropdownText.TextXAlignment = Enum.TextXAlignment.Left

                local DropdownArrow = Instance.new("ImageLabel")
                DropdownArrow.Parent = DropdownFrame
                DropdownArrow.BackgroundTransparency = 1
                DropdownArrow.Position = UDim2.new(1, -35, 0, 10)
                DropdownArrow.Size = UDim2.new(0, 24, 0, 24)
                DropdownArrow.Image = "rbxassetid://6031302934"
                DropdownArrow.ImageColor3 = Color3.fromRGB(120, 120, 125)
                DropdownArrow.Rotation = 180

                local OptionContainer = Instance.new("Frame")
                OptionContainer.Parent = DropdownFrame
                OptionContainer.BackgroundTransparency = 1
                OptionContainer.Position = UDim2.new(0, 10, 0, 44)
                OptionContainer.Size = UDim2.new(1, -20, 0, 0)

                local OptionLayout = Instance.new("UIListLayout")
                OptionLayout.Parent = OptionContainer
                OptionLayout.SortOrder = Enum.SortOrder.LayoutOrder
                OptionLayout.Padding = UDim.new(0, 4)

                local DropdownBtn = Instance.new("TextButton")
                DropdownBtn.Parent = DropdownFrame
                DropdownBtn.BackgroundTransparency = 1
                DropdownBtn.Size = UDim2.new(1, 0, 0, 44)
                DropdownBtn.Text = ""

                local open = false
                local selectedOption = nil

                local function toggleDropdown()
                    open = not open
                    Tween(DropdownArrow, 0.3, {Rotation = open and 0 or 180})
                    local contentHeight = #options * 36 + (#options - 1) * 4
                    Tween(DropdownFrame, 0.3, {Size = UDim2.new(1, 0, 0, open and 48 + contentHeight or 44)})
                end

                DropdownBtn.MouseButton1Click:Connect(toggleDropdown)

                local funcs = {}

                function funcs.SetOptions(self, newOptions)
                    for _, child in ipairs(OptionContainer:GetChildren()) do
                        if child:IsA("TextButton") then child:Destroy() end
                    end
                    options = newOptions

                    for i, option in ipairs(options) do
                        local OptionBtn = Instance.new("TextButton")
                        OptionBtn.Parent = OptionContainer
                        OptionBtn.BackgroundColor3 = iOSColors.SurfaceElevated
                        OptionBtn.BorderSizePixel = 0
                        OptionBtn.Size = UDim2.new(1, 0, 0, 36)
                        OptionBtn.AutoButtonColor = false
                        OptionBtn.Font = Enum.Font.Gotham
                        OptionBtn.Text = "   " .. option
                        OptionBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
                        OptionBtn.TextSize = 13
                        OptionBtn.TextXAlignment = Enum.TextXAlignment.Left

                        local OptionCorner = Instance.new("UICorner")
                        OptionCorner.CornerRadius = UDim.new(0, 8)
                        OptionCorner.Parent = OptionBtn

                        OptionBtn.MouseEnter:Connect(function()
                            Tween(OptionBtn, 0.2, {BackgroundColor3 = Color3.fromRGB(70, 70, 75)})
                        end)

                        OptionBtn.MouseLeave:Connect(function()
                            Tween(OptionBtn, 0.2, {BackgroundColor3 = iOSColors.SurfaceElevated})
                        end)

                        OptionBtn.MouseButton1Click:Connect(function()
                            selectedOption = option
                            library.flags[flag] = option
                            DropdownText.Text = text .. ": " .. option
                            toggleDropdown()
                            callback(option)
                        end)
                    end
                end

                funcs:SetOptions(options)
                return funcs
            end

            function section.Keybind(section, text, default, callback)
                callback = callback or function() end
                default = default or "None"

                local KeybindFrame = Instance.new("Frame")
                KeybindFrame.Name = text .. "_Keybind"
                KeybindFrame.Parent = Objs
                KeybindFrame.BackgroundColor3 = iOSColors.Surface
                KeybindFrame.BorderSizePixel = 0
                KeybindFrame.Size = UDim2.new(1, 0, 0, 44)

                local KeybindCorner = Instance.new("UICorner")
                KeybindCorner.CornerRadius = UDim.new(0, 10)
                KeybindCorner.Parent = KeybindFrame

                local KeybindText = Instance.new("TextLabel")
                KeybindText.Parent = KeybindFrame
                KeybindText.BackgroundTransparency = 1
                KeybindText.Position = UDim2.new(0, 15, 0, 0)
                KeybindText.Size = UDim2.new(0.6, 0, 1, 0)
                KeybindText.Font = Enum.Font.GothamSemibold
                KeybindText.Text = text
                KeybindText.TextColor3 = Color3.fromRGB(255, 255, 255)
                KeybindText.TextSize = 14
                KeybindText.TextXAlignment = Enum.TextXAlignment.Left

                local KeybindValue = Instance.new("TextButton")
                KeybindValue.Parent = KeybindFrame
                KeybindValue.BackgroundColor3 = iOSColors.SurfaceElevated
                KeybindValue.Position = UDim2.new(1, -80, 0.5, -14)
                KeybindValue.Size = UDim2.new(0, 70, 0, 28)
                KeybindValue.AutoButtonColor = false
                KeybindValue.Font = Enum.Font.GothamBold
                KeybindValue.Text = default
                KeybindValue.TextColor3 = iOSColors.Primary
                KeybindValue.TextSize = 12

                local ValueCorner = Instance.new("UICorner")
                ValueCorner.CornerRadius = UDim.new(0, 6)
                ValueCorner.Parent = KeybindValue

                local listening = false
                local currentKey = default

                KeybindValue.MouseButton1Click:Connect(function()
                    if listening then return end
                    listening = true
                    KeybindValue.Text = "..."

                    local conn
                    conn = UserInputService.InputBegan:Connect(function(input)
                        if input.KeyCode ~= Enum.KeyCode.Unknown then
                            currentKey = input.KeyCode.Name
                            KeybindValue.Text = currentKey
                            listening = false
                            conn:Disconnect()
                        end
                    end)
                end)

                UserInputService.InputBegan:Connect(function(input)
                    if input.KeyCode.Name == currentKey then
                        callback(currentKey)
                    end
                end)
            end

            function section.Textbox(section, text, flag, default, callback)
                callback = callback or function() end
