function Tween(obj, duration, data, style)
    local easingStyle = style or Enum.EasingStyle.Sine
    local tweenInfo = TweenInfo.new(duration, easingStyle, Enum.EasingDirection.InOut)
    TweenService:Create(obj, tweenInfo, data):Play()
    return true
end

function SpringTween(obj, duration, data)
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Elastic, Enum.EasingDirection.Out, 0, false, 0)
    TweenService:Create(obj, tweenInfo, data):Play()
end

function PopTween(obj, duration, data)
    local tweenInfo = TweenInfo.new(duration, Enum.EasingStyle.Back, Enum.EasingDirection.Out)
    TweenService:Create(obj, tweenInfo, data):Play()
end

local switchingTabs = false

function switchTab(new)
    if switchingTabs then return end
    local old = library.currentTab
    if old == nil then
        new[2].Visible = true
        library.currentTab = new
        Tween(new[1], 0.2, {ImageTransparency = 0})
        Tween(new[1].TabText, 0.2, {TextTransparency = 0})
        if new[1]:FindFirstChild("ActiveIndicator") then
            SpringTween(new[1].ActiveIndicator, 0.4, {Size = UDim2.new(1, 0, 0, 2)})
        end
        return
    end
    if old[1] == new[1] then return end
    switchingTabs = true
    library.currentTab = new
    Tween(old[1], 0.2, {ImageTransparency = 0.2})
    Tween(new[1], 0.2, {ImageTransparency = 0})
    Tween(old[1].TabText, 0.2, {TextTransparency = 0.2})
    Tween(new[1].TabText, 0.2, {TextTransparency = 0})
    if old[1]:FindFirstChild("ActiveIndicator") then
        Tween(old[1].ActiveIndicator, 0.2, {Size = UDim2.new(0, 0, 0, 2)})
    end
    if new[1]:FindFirstChild("ActiveIndicator") then
        SpringTween(new[1].ActiveIndicator, 0.4, {Size = UDim2.new(1, 0, 0, 2)})
    end
    old[2].Visible = false
    new[2].Visible = true
    task.wait(0.2)
    switchingTabs = false
end

function drag(frame, hold)
    if not hold then hold = frame end
    local dragging, dragInput, dragStart, startPos
    local function update(input)
        local delta = input.Position - dragStart
        frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
    hold.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then dragging = false end
            end)
        end
    end)
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then dragInput = input end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then update(input) end
    end)
end

