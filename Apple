                        if precise then
                            value = math.floor(value * 10) / 10
                        else
                            value = math.floor(value)
                        end
                        library.flags[flag] = value
                        SliderValue.Text = tostring(value)
                        SliderFill.Size = UDim2.new((value - min) / (max - min), 0, 1, 0)
                        callback(value)
                    end
                }
            end
            
