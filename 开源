local function safe(s) return tostring(s):gsub('[\\/:*?"<>|@]', "_") end
local function caller() 
    local i = debug.getinfo(3) 
    return i and ((i.short_src or "?") .. "_" .. (i.currentline or "?")) or "?"
end

local stats = {total = 0, loadstring = 0, HttpGet = 0, HttpGetAsync = 0, request = 0, require = 0, namecall = 0, task_spawn = 0, task_defer = 0, table_concat = 0, webhooks = 0}
local urls = {}
local dump_i = 0
local current_file_path = nil

local function write_summary()
    local t = {}
    table.insert(t, "事件ID: " .. event_id)
    table.insert(t, "时间: " .. event_time)
    table.insert(t, "总转储: " .. stats.total)
    table.insert(t, "Webhooks: " .. stats.webhooks)
    table.insert(t, "")
    for k, v in pairs(stats) do 
        if k ~= "total" and k ~= "webhooks" then 
            table.insert(t, k .. ": " .. v) 
        end 
    end
    table.insert(t, "")
    table.insert(t, "URLs:")
    for u, _ in pairs(urls) do table.insert(t, "- " .. u) end
    
    if writefile then 
        pcall(function() writefile(folder .. "/总日志.txt", table.concat(t, "\n")) end) 
    end
end

local function append_log(path, content)
    if appendfile then
        appendfile(path, content)
    else
        local old = isfile(path) and readfile(path) or ""
        writefile(path, old .. content)
    end
end

local function dump(tag, content, extra)
    stats.total = stats.total + 1
    if stats[tag] then stats[tag] = stats[tag] + 1 end
    
    local is_log_only = (tag == "HttpGet" or tag == "HttpGetAsync" or tag:find("namecall_Http"))
    
    if extra and type(extra) == "string" and extra:match("^https?://") then 
        urls[extra] = true 
        if extra:lower():find("webhook") or extra:lower():find("discord.com/api") then
            stats.webhooks = stats.webhooks + 1
            local wh_entry = string.format("[%s] 来源: %s\nURL: %s\n\n", os.date("%H:%M:%S"), tag, extra)
            pcall(function() append_log(webhook_log_path, wh_entry) end)
        end
    end

    if is_log_only then
        local log_entry = string.format("[%s] [%s]\n调用: %s\nURL: %s\n--------------------------------\n", os.date("%H:%M:%S"), tag, caller(), tostring(extra or "nil"))
        pcall(function() append_log(http_log_path, log_entry) end)
    else
        dump_i = dump_i + 1
        local name = safe(string.format("%03d_%s.lua", dump_i, tag))
        local path = folder .. "/" .. name
        local header = string.format("--[[\n时间: %s\n类型: %s\n调用: %s\n%s]]\n\n", os.date("%H:%M:%S"), tag, caller(), extra and ("信息: " .. tostring(extra) .. "\n") or "")
        
        if writefile then 
            pcall(function() writefile(path, header .. tostring(content)) end) 
        end
    end
    
    write_summary()
end

local function safe_hook(f) pcall(f) end

safe_hook(function()
    local old = loadstring
    getgenv().loadstring = function(s, n) dump("脚本代码", s) return old(s, n) end
end)

safe_hook(function()
    local old = require
    require = function(m) dump("require", m) return old(m) end
end)

safe_hook(function()
    if game.HttpGet then
        local old = game.HttpGet
        game.HttpGet = function(s, u, ...) dump("HttpGet", nil, u) return old(s, u, ...) end
    end
end)

safe_hook(function()
    if game.HttpGetAsync then
        local old = game.HttpGetAsync
        game.HttpGetAsync = function(s, u, ...) dump("HttpGetAsync", nil, u) return old(s, u, ...) end
    end
end)

safe_hook(function()
    local mt = getrawmetatable(game)
    if mt then
        local old = mt.__namecall
        setreadonly(mt, false)
        mt.__namecall = function(self, ...)
            local m = getnamecallmethod()
            if m == "HttpGet" or m == "HttpGetAsync" then
                dump("namecall_" .. m, nil, ({...})[1])
            end
            return old(self, ...)
        end
        setreadonly(mt, true)
    end
end)

safe_hook(function()
    local req = getgenv().request or getgenv().http_request or (syn and syn.request)
    if req then
        getgenv().request = function(t) dump("request", t.Body, t.Url) return req(t) end
    end
end)

safe_hook(function()
    local old_s, old_d = task.spawn, task.defer
    task.spawn = function(f, ...) dump("task_spawn", debug.getinfo(f).source) return old_s(f, ...) end
    task.defer = function(f, ...) dump("task_defer", debug.getinfo(f).source) return old_d(f, ...) end
end)

