    while gui.Parent do
        local s_txt = "<b>状态:</b> <font color='#D4AF37'>● 运行中</font>\n\n"
        s_txt = s_txt .. "总计: <b>" .. stats.total .. "</b>\n"
        s_txt = s_txt .. "脚本: " .. stats.loadstring .. "\n"
        s_txt = s_txt .. "网络: " .. (stats.HttpGet + stats.HttpGetAsync + stats.request) .. "\n"
        s_txt = s_txt .. "Webhooks: <font color='" .. (stats.webhooks > 0 and "#D4AF37" or "#757575") .. "'>" .. stats.webhooks .. "</font>\n\n"
        s_txt = s_txt .. "<b>最近URL:</b>\n"
        
        local c = 0
        for u, _ in pairs(urls) do
            if c < 6 then
                local trimmed = u:sub(1, 28)
                if #u > 28 then trimmed = trimmed .. "..." end
                s_txt = s_txt .. "<font color='#9E9E9E'>• " .. trimmed .. "</font>\n"
                c = c + 1
            end
        end
        
        if c == 0 then s_txt = s_txt .. "<font color='#616161'>暂无数据</font>" end
        stat_lbl.Text = s_txt
        
        pcall(update_file_list)
        task.wait(1)
    end
end)

update_file_list()