local function load_file(path)
    if not isfile(path) then return end
    current_file_path = path
    view_header.Text = "查看器: " .. path:match("[^\\/]+$")
    meta_txt.Text = "<font color='#D4AF37'>加载中...</font>"
    
    for _, child in ipairs(code_bg:GetChildren()) do
        if child:IsA("TextLabel") and child ~= meta_txt then child:Destroy() end
    end
    
    task.spawn(function()
        task.wait()
        local c = readfile(path)
        local size = #c
        local lines = 1
        for _ in c:gmatch("\n") do lines = lines + 1 end
        
        meta_txt.Text = string.format("<font color='#D4AF37'>[ %d行 | %d字节 ]</font>", lines, size)
        c = c:gsub("%z", " ")
        
        local len = string.len(c)
        for i = 1, len, 80000 do
            local chunk = string.sub(c, i, i + 80000 - 1)
            create("TextLabel", {
                Size = UDim2.new(0, 0, 0, 0),
                AutomaticSize = Enum.AutomaticSize.XY,
                BackgroundTransparency = 1,
                TextColor3 = ui_config.colors.text,
                Font = Enum.Font.Code,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextWrapped = false,
                Text = chunk,
                LayoutOrder = i,
                Parent = code_bg
            })
            if (i / 80000) % 5 == 0 then task.wait() end
        end
        code_sc.CanvasPosition = Vector2.new(0, 0)
    end)
end

local known_files = {}
local function update_file_list()
    if not isfolder(folder) then return end
    
    local raw_files = listfiles(folder)
    local files = {}
    for _, p in ipairs(raw_files) do
        local n = p:match("[^\\/]+$")
        if n and n ~= "summary.txt" then 
            table.insert(files, {name = n, path = p}) 
        end
    end
    table.sort(files, function(a, b) return a.name < b.name end)
    
    if #files ~= #known_files then
        for _, c in ipairs(list_sc:GetChildren()) do 
            if c:IsA("TextButton") then c:Destroy() end 
        end
        
        known_files = files
        for _, f in ipairs(files) do
            local btn = create("TextButton", {
                Size = UDim2.new(1, -4, 0, 22),
                BackgroundColor3 = ui_config.colors.button,
                Text = "",
                Parent = list_sc
            })
            btn:SetAttribute("FilePath", f.path)
            
            local txt = create("TextLabel", {
                Text = "  " .. f.name,
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundTransparency = 1,
                TextColor3 = ui_config.colors.text,
                TextXAlignment = 0,
                Font = Enum.Font.Code,
                TextSize = 12,
                Parent = btn
            })
            
            add_corner(btn, UDim.new(0, 4))
            
            btn.MouseButton1Click:Connect(function() load_file(f.path) end)
            btn.MouseEnter:Connect(function()
                btn.BackgroundColor3 = ui_config.colors.button_hover
                if current_file_path ~= f.path then txt.TextColor3 = ui_config.colors.accent end
            end)
            btn.MouseLeave:Connect(function()
                btn.BackgroundColor3 = ui_config.colors.button
                if current_file_path ~= f.path then txt.TextColor3 = ui_config.colors.text end
            end)
        end
        
        list_sc.CanvasSize = UDim2.new(0, 0, 0, #files * 25)
    end
    
    for _, btn in ipairs(list_sc:GetChildren()) do
        if btn:IsA("TextButton") then
            local txt = btn:FindFirstChild("TextLabel")
            if txt then
                if btn:GetAttribute("FilePath") == current_file_path then
                    txt.TextColor3 = ui_config.colors.selected
                    txt.Font = Enum.Font.GothamBold
                else
                    txt.TextColor3 = ui_config.colors.text
                    txt.Font = Enum.Font.Code
                end
            end
        end
    end
end

