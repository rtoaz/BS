local function Drag(frame, hold)
    hold = hold or frame
    local dragging = false
    local dragInput
    local dragStart
    local startPos
    
    local function Update(input)
        local delta = input.Position - dragStart
        Creator.Tween(frame, {0.1, "Sine", "Out"}, {
            Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        })
    end
    
    hold.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            
            Creator.Tween(frame, {0.1, "Quint", "Out"}, {Size = UDim2.new(frame.Size.X.Scale, frame.Size.X.Offset + 4, frame.Size.Y.Scale, frame.Size.Y.Offset + 4)})
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                    Creator.Tween(frame, {0.2, "Elastic", "Out"}, {Size = UDim2.new(frame.Size.X.Scale, frame.Size.X.Offset - 4, frame.Size.Y.Scale, frame.Size.Y.Offset - 4)})
                end
            end)
        end
    end)
    
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)
    
    Services.UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            Update(input)
        end
    end)
end

local switchingTabs = false
local function SwitchTab(newTabData)
    if switchingTabs then return end
    local oldTab = WindUIMigration.currentTab
    if oldTab == nil then
        newTabData.Content.Visible = true
        WindUIMigration.currentTab = newTabData
        Creator.Tween(newTabData.Button, {0.3, "Quint", "Out"}, {ImageTransparency = 0})
        Creator.Tween(newTabData.Text, {0.3, "Quint", "Out"}, {TextTransparency = 0})
        return
    end
    
    if oldTab.Button == newTabData.Button then return end
    switchingTabs = true
    
    Creator.Tween(oldTab.Button, {0.2, "Quint", "Out"}, {ImageTransparency = 0.7})
    Creator.Tween(oldTab.Text, {0.2, "Quint", "Out"}, {TextTransparency = 0.3})
    Creator.Tween(newTabData.Button, {0.2, "Quint", "Out"}, {ImageTransparency = 0})
    Creator.Tween(newTabData.Text, {0.2, "Quint", "Out"}, {TextTransparency = 0})
    
    oldTab.Content.Visible = false
    newTabData.Content.Visible = true
    
    WindUIMigration.currentTab = newTabData
    task.wait(0.2)
    switchingTabs = false
end

