                })
                
                local function Toggle()
                    open = not open
                    if open then
                        Creator.Tween(container, {0.3, "Quint", "Out"}, {
                            Size = UDim2.new(1, 0, 0, 50 + optionsList.AbsoluteContentSize.Y)
                        })
                        Creator.Tween(arrow, {0.3, "Quint", "Out"}, {Rotation = 180})
                    else
                        Creator.Tween(container, {0.3, "Quint", "Out"}, {Size = UDim2.new(1, 0, 0, 40)})
                        Creator.Tween(arrow, {0.3, "Quint", "Out"}, {Rotation = 0})
                    end
                end
                
                header.MouseButton1Click:Connect(Toggle)
                
                for _, option in ipairs(options) do
                    local optBtn = Creator.NewRoundFrame(6, "Squircle", {
                        Parent = optionsContainer,
                        Size = UDim2.new(1, 0, 0, 30),
                        ImageColor3 = Theme.Background,
                        ImageTransparency = 0.5
                    })
                    
                    Creator.New("TextLabel", {
                        Parent = optBtn,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, -20, 1, 0),
