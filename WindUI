            function sectionObj.Slider(section, text, flag, default, min, max, precise, callback)
                callback = callback or function() end
                min = min or 1
                max = max or 100
                default = default or min
                precise = precise or false
                WindUIMigration.flags[flag] = default
                
                local dragging = false
                
                local container = Creator.NewRoundFrame(8, "Squircle", {
                    Parent = elementContainer,
                    Size = UDim2.new(1, 0, 0, 50),
                    ImageColor3 = Theme.ElementBG,
                    ImageTransparency = 0.3
                })
                
                Creator.New("TextLabel", {
                    Parent = container,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, -20, 0, 25),
                    Position = UDim2.new(0, 15, 0, 5),
                    Font = Enum.Font.GothamSemibold,
                    Text = text,
                    TextColor3 = Theme.Text,
                    TextSize = 15,
                    TextXAlignment = Enum.TextXAlignment.Left
                })
                
                local track = Creator.NewRoundFrame(4, "Squircle", {
                    Parent = container,
                    Size = UDim2.new(1, -100, 0, 8),
                    Position = UDim2.new(0, 15, 0, 32),
                    ImageColor3 = Theme.Background,
                    ImageTransparency = 0.5
                })
                
                local fill = Creator.NewRoundFrame(4, "Squircle", {
                    Parent = track,
                    Size = UDim2.new((default - min)/(max - min), 0, 1, 0),
                    ImageColor3 = Theme.Primary
                })
                
                local knob = Creator.NewRoundFrame(8, "Squircle", {
                    Parent = fill,
                    Size = UDim2.new(0, 16, 0, 16),
                    Position = UDim2.new(1, -8, 0.5, -8),
                    ImageColor3 = Color3.fromRGB(255, 255, 255),
                    ImageTransparency = 0
                })
                
                local valueBox = Creator.NewRoundFrame(6, "Squircle", {
                    Parent = container,
                    Size = UDim2.new(0, 50, 0, 24),
                    Position = UDim2.new(1, -65, 0, 24),
                    ImageColor3 = Theme.Background,
                    ImageTransparency = 0.2
                })
                
                local valueText = Creator.New("TextBox", {
                    Parent = valueBox,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 1, 0),
                    Font = Enum.Font.Gotham,
                    Text = tostring(default),
                    TextColor3 = Theme.Text,
                    TextSize = 13
                })
                
                local function UpdateValue(val)
                    val = math.clamp(val, min, max)
                    if precise then
                        val = tonumber(string.format("%.1f", val))
                    else
                        val = math.floor(val)
                    end
                    
                    WindUIMigration.flags[flag] = val
                    valueText.Text = tostring(val)
                    Creator.Tween(fill, {0.1, "Quint", "Out"}, {
                        Size = UDim2.new((val - min)/(max - min), 0, 1, 0)
                    })
                    callback(val)
                end
                
                track.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                        local percent = math.clamp((input.Position.X - track.AbsolutePosition.X)/track.AbsoluteSize.X, 0, 1)
                        UpdateValue(min + (max - min) * percent)
                    end
                end)
                
                Services.UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = false
                    end
                end)
                
                Services.UserInputService.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        local percent = math.clamp((input.Position.X - track.AbsolutePosition.X)/track.AbsoluteSize.X, 0, 1)
                        UpdateValue(min + (max - min) * percent)
                    end
                end)
                
                valueText.FocusLost:Connect(function()
                    local val = tonumber(valueText.Text) or default
                    UpdateValue(val)
                end)
                
                local funcs = {
                    SetValue = UpdateValue
                }
                return funcs
            end
            
