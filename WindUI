                        TextColor3 = Theme.Text,
                        TextSize = 14,
                        TextXAlignment = Enum.TextXAlignment.Left
                    })
                    
                    local hit = Creator.New("TextButton", {
                        Parent = optBtn,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 1, 0),
                        Text = ""
                    })
                    
                    hit.MouseEnter:Connect(function()
                        Creator.Tween(optBtn, {0.2, "Quint", "Out"}, {ImageTransparency = 0.3})
                    end)
                    
                    hit.MouseLeave:Connect(function()
                        Creator.Tween(optBtn, {0.2, "Quint", "Out"}, {ImageTransparency = 0.5})
                    end)
                    
                    hit.MouseButton1Click:Connect(function()
                        selectedText.Text = option
                        WindUIMigration.flags[flag] = option
                        callback(option)
                        Toggle()
                    end)
                end
                
                local funcs = {
                    AddOption = function(self, opt) end,
                    RemoveOption = function(self, opt) end
                }
                return funcs
            end
            
            task.wait()
            UpdateSectionSize()
            
            return sectionObj
        end
        
        return tabObj
    end
    
