function Creator.Tween(obj, timeInfo, properties)
    local tweenInfo = TweenInfo.new(
        timeInfo[1], 
        Enum.EasingStyle[timeInfo[2]], 
        Enum.EasingDirection[timeInfo[3]]
    )
    local tween = Services.TweenService:Create(obj, tweenInfo, properties)
    tween:Play()
    return tween
end

function Creator.Ripple(parent, x, y)
    task.spawn(function()
        if not parent then return end
        
        local ripple = Creator.New("ImageLabel", {
            Name = "WindRipple",
            BackgroundTransparency = 1,
            Image = "rbxassetid://18941591417",
            ImageColor3 = Color3.fromRGB(129, 90, 220),
            ImageTransparency = 0.6,
            ScaleType = Enum.ScaleType.Fit,
            Position = UDim2.new(0, x - parent.AbsolutePosition.X - 50, 0, y - parent.AbsolutePosition.Y - 50),
            Size = UDim2.new(0, 100, 0, 100),
            ZIndex = 10,
            Parent = parent
        })
        
        Creator.Tween(ripple, {0.5, "Quint", "Out"}, {
            Position = UDim2.new(0, x - parent.AbsolutePosition.X - 100, 0, y - parent.AbsolutePosition.Y - 100),
            Size = UDim2.new(0, 200, 0, 200),
            ImageTransparency = 1
        })
        
        task.wait(0.5)
        if ripple then ripple:Destroy() end
    end)
end

