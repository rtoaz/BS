                local SliderBar = Creator.NewRoundFrame(4, "Squircle", {
                    Parent = SliderModule,
                    Size = UDim2.new(1, -100, 0, 8),
                    Position = UDim2.new(0, 15, 0, 32),
                    ImageColor3 = Background,
                    ImageTransparency = 0.5
                })
                
                local SliderPart = Creator.NewRoundFrame(4, "Squircle", {
                    Parent = SliderBar,
                    Size = UDim2.new((default - min)/(max - min), 0, 1, 0),
                    ImageColor3 = Color3.fromRGB(129, 90, 220)
                })
                
                local SliderKnob = Creator.NewRoundFrame(8, "Squircle", {
                    Parent = SliderPart,
                    Size = UDim2.new(0, 16, 0, 16),
                    Position = UDim2.new(1, -8, 0.5, -8),
                    ImageColor3 = Color3.fromRGB(255, 255, 255)
                })
                
                local ValBtn = Creator.NewRoundFrame(6, "Squircle", {
                    Parent = SliderModule,
                    Size = UDim2.new(0, 50, 0, 24),
                    Position = UDim2.new(1, -65, 0, 24),
                    ImageColor3 = Background,
                    ImageTransparency = 0.2
                })
                
                local SliderValue = Instance.new("TextBox")
                SliderValue.Parent = ValBtn
                SliderValue.BackgroundTransparency = 1
                SliderValue.Size = UDim2.new(1, 0, 1, 0)
                SliderValue.Font = Enum.Font.Gotham
                SliderValue.Text = tostring(default)
                SliderValue.TextColor3 = ALcolor
                SliderValue.TextSize = 14
                
                local dragging = false
                local funcs = {}
                
                funcs.SetValue = function(self, value)
                    if value == nil then return end
                    local percent = (value - min) / (max - min)
                    percent = math.clamp(percent, 0, 1)
                    value = precise and tonumber(string.format("%.1f", value)) or math.floor(value + 0.5)
                    value = math.clamp(value, min, max)
                    
                    library.flags[flag] = value
                    SliderValue.Text = tostring(value)
                    Tween(SliderPart, {0.1, "Quint", "Out"}, {Size = UDim2.new(percent, 0, 1, 0)})
                    callback(value)
                end
                
                SliderBar.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = true
                        local percent = math.clamp((input.Position.X - SliderBar.AbsolutePosition.X)/SliderBar.AbsoluteSize.X, 0, 1)
                        funcs:SetValue(min + (max - min) * percent)
                    end
                end)
                
                services.UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 then
                        dragging = false
                    end
                end)
                
                services.UserInputService.InputChanged:Connect(function(input)
                    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                        local percent = math.clamp((input.Position.X - SliderBar.AbsolutePosition.X)/SliderBar.AbsoluteSize.X, 0, 1)
                        funcs:SetValue(min + (max - min) * percent)
                    end
                end)
                
                SliderValue.FocusLost:Connect(function()
                    local val = tonumber(SliderValue.Text) or default
                    funcs:SetValue(val)
                end)
                
                funcs:SetValue(default)
                return funcs
            end
            
