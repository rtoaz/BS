local function Tween(obj, t, data)
    TweenService:Create(obj, TweenInfo.new(t[1], Enum.EasingStyle[t[2]], Enum.EasingDirection[t[3]]), data):Play()
    return true
end

local Creator = {}
function Creator.New(className, properties, children)
    local instance = Instance.new(className)
    for prop, value in pairs(properties or {}) do
        if prop ~= "ThemeTag" then
            instance[prop] = value
        end
    end
    
    if properties and properties.ThemeTag then
        for prop, colorName in pairs(properties.ThemeTag) do
            local colors = {
                Background = Color3.fromRGB(30, 30, 30),
                ElementBackground = Color3.fromRGB(35, 35, 35),
                Primary = Color3.fromRGB(129, 90, 220),
                Text = Color3.fromRGB(240, 240, 240),
                Icon = Color3.fromRGB(200, 200, 200),
                Hover = Color3.fromRGB(45, 45, 45)
            }
            instance[prop] = colors[colorName] or Color3.fromRGB(255,255,255)
        end
    end
    
    if children then
        for _, child in ipairs(children) do
            child.Parent = instance
        end
    end
    return instance
end

