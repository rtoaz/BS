        end
    end)

    PageContainer.InputEnded:Connect(function(input)
        if touchStart and (input.UserInputType == Enum.UserInputType.Touch or input.UserInputType == Enum.UserInputType.MouseButton1) then
            local delta = input.Position.X - touchStart
            if math.abs(delta) > 50 then
                if delta < 0 and currentPage < totalPages then
                    showPage(currentPage + 1)
                elseif delta > 0 and currentPage > 1 then
                    showPage(currentPage - 1)
                end
            end
            touchStart = nil
        end
    end)

