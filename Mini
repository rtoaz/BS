                valBox.TextColor3 = TextColor
                valBox.TextSize = 14
                
                local vC = Instance.new("UICorner")
                vC.Parent = valBox
                vC.CornerRadius = UDim.new(0, 6)
                
                local barBg = Instance.new("Frame")
                barBg.Parent = slider
                barBg.BackgroundColor3 = Background
                barBg.BackgroundTransparency = 0.6
                barBg.Position = UDim2.new(0, 15, 0, 38)
                barBg.Size = UDim2.new(0.7, 0, 0, 8)
                
                local bC = Instance.new("UICorner")
                bC.Parent = barBg
                bC.CornerRadius = UDim.new(0, 4)
                
                local fill = Instance.new("Frame")
                fill.Parent = barBg
                fill.BackgroundColor3 = beijingColor
                fill.Size = UDim2.new((default - min)/(max - min), 0, 1, 0)
                
                local fC = Instance.new("UICorner")
                fC.Parent = fill
                fC.CornerRadius = UDim.new(0, 4)
                
                local dragging = false
                
                local function updateValue(input)
                    local pos = math.clamp((input.Position.X - barBg.AbsolutePosition.X) / barBg.AbsoluteSize.X, 0, 1)
                    local val = min + (max - min) * pos
                    if not precise then val = math.floor(val) end
                    val = tonumber(string.format(precise and "%.2f" or "%.0f", val))
                    library.flags[flag] = val
                    valBox.Text = tostring(val)
                    fill.Size = UDim2.new(pos, 0, 1, 0)
                    callback(val)
                end
                
                barBg.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = true
                        updateValue(input)
                    end
                end)
                
                UserInputService.InputChanged:Connect(function(input)
                    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                        updateValue(input)
                    end
                end)
                
                UserInputService.InputEnded:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                        dragging = false
                    end
                end)
                
                valBox.FocusLost:Connect(function()
                    local num = tonumber(valBox.Text) or default
                    num = math.clamp(num, min, max)
                    if not precise then num = math.floor(num) end
                    library.flags[flag] = num
                    valBox.Text = tostring(num)
                    fill.Size = UDim2.new((num - min)/(max - min), 0, 1, 0)
                    callback(num)
                end)
                
                return {
                    SetValue = function(self, val)
                        val = math.clamp(val, min, max)
                        if not precise then val = math.floor(val) end
                        library.flags[flag] = val
                        valBox.Text = tostring(val)
                        fill.Size = UDim2.new((val - min)/(max - min), 0, 1, 0)
                        callback(val)
                    end
                }
            end

            function secObj.Dropdown(text, flag, options, callback)
                options = options or {}
                library.flags[flag] = nil
                callback = callback or function() end
                
                local drop = Instance.new("TextButton")
                drop.Parent = Objs
                drop.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
                drop.BackgroundTransparency = 0.3
                drop.Size = UDim2.new(1, 0, 0, 45)
                drop.Font = Enum.Font.GothamBold
                drop.Text = ""
                drop.AutoButtonColor = false
                
                local dC = Instance.new("UICorner")
                dC.Parent = drop
                dC.CornerRadius = UDim.new(0, 10)
                
                local lbl = Instance.new("TextLabel")
                lbl.Parent = drop
                lbl.BackgroundTransparency = 1
                lbl.Position = UDim2.new(0, 15, 0, 0)
                lbl.Size = UDim2.new(0.7, 0, 1, 0)
                lbl.Font = Enum.Font.GothamBold
                lbl.Text = text
                lbl.TextColor3 = TextColor
                lbl.TextSize = 15
                lbl.TextXAlignment = Enum.TextXAlignment.Left
                
                local arrow = Instance.new("TextLabel")
                arrow.Parent = drop
                arrow.BackgroundTransparency = 1
                arrow.Position = UDim2.new(0.9, -20, 0, 0)
                arrow.Size = UDim2.new(0, 30, 1, 0)
                arrow.Font = Enum.Font.GothamBold
                arrow.Text = "▼"
                arrow.TextColor3 = TextColor
                arrow.TextSize = 14
                
                local selectedText = Instance.new("TextLabel")
                selectedText.Parent = drop
                selectedText.BackgroundTransparency = 1
                selectedText.Position = UDim2.new(0.5, 0, 0, 0)
                selectedText.Size = UDim2.new(0.4, -10, 1, 0)
                selectedText.Font = Enum.Font.GothamBold
                selectedText.Text = ""
                selectedText.TextColor3 = PlaceholderColor
                selectedText.TextSize = 14
                selectedText.TextXAlignment = Enum.TextXAlignment.Right
                
                local dropFrame = Instance.new("Frame")
                dropFrame.Parent = drop
                dropFrame.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
                dropFrame.BackgroundTransparency = 0.1
                dropFrame.Position = UDim2.new(0, 0, 1, 5)
                dropFrame.Size = UDim2.new(1, 0, 0, 0)
                dropFrame.ClipsDescendants = true
                dropFrame.ZIndex = 10
                dropFrame.Visible = false
                
                local dfC = Instance.new("UICorner")
                dfC.Parent = dropFrame
                dfC.CornerRadius = UDim.new(0, 10)
                
                local dropLayout = Instance.new("UIListLayout")
                dropLayout.Parent = dropFrame
                dropLayout.SortOrder = Enum.SortOrder.LayoutOrder
                dropLayout.Padding = UDim.new(0, 5)
                
                local open = false
                
                local function toggle()
                    open = not open
                    dropFrame.Visible = true
                    if open then
                        Tween(dropFrame, {0.2, "Quad", "Out"}, {Size = UDim2.new(1, 0, 0, math.min(#options * 35, 150))})
                        arrow.Text = "▲"
                    else
                        Tween(dropFrame, {0.2, "Quad", "Out"}, {Size = UDim2.new(1, 0, 0, 0)})
                        wait(0.2)
                        dropFrame.Visible = false
                        arrow.Text = "▼"
                    end
                end
                
                drop.MouseButton1Click:Connect(toggle)
                
                for _, opt in ipairs(options) do
                    local btn = Instance.new("TextButton")
                    btn.Parent = dropFrame
                    btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
                    btn.BackgroundTransparency = 0.5
                    btn.Size = UDim2.new(1, -10, 0, 30)
                    btn.Position = UDim2.new(0, 5, 0, 0)
                    btn.Font = Enum.Font.GothamBold
                    btn.Text = opt
                    btn.TextColor3 = TextColor
                    btn.TextSize = 13
                    btn.ZIndex = 11
                    
                    local bC = Instance.new("UICorner")
                    bC.Parent = btn
                    bC.CornerRadius = UDim.new(0, 6)
                    
                    btn.MouseButton1Click:Connect(function()
                        selectedText.Text = opt
                        library.flags[flag] = opt
                        callback(opt)
                        toggle()
                    end)
                end
                
                return {
                    SetOptions = function(self, newOpts)
                        for _, child in pairs(dropFrame:GetChildren()) do
                            if child:IsA("TextButton") then child:Destroy() end
                        end
                        options = newOpts
                        for _, opt in ipairs(options) do
                            local btn = Instance.new("TextButton")
                            btn.Parent = dropFrame
                            btn.BackgroundColor3 = Color3.fromRGB(60, 60, 60)
                            btn.Size = UDim2.new(1, -10, 0, 30)
                            btn.Font = Enum.Font.GothamBold
                            btn.Text = opt
                            btn.TextColor3 = TextColor
                            btn.ZIndex = 11
                            btn.MouseButton1Click:Connect(function()
                                selectedText.Text = opt
                                library.flags[flag] = opt
                                callback(opt)
                                toggle()
                            end)
                        end
                    end
                }
            end

            return secObj
        end

        table.insert(window.tabs, tabObj)
        return tabObj
    end

    return window
end

return library