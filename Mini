    local function createDot(index)
        local dot = Instance.new("TextButton")
        dot.Parent = DotContainer
        dot.BackgroundColor3 = index == 1 and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(100, 100, 100)
        dot.BorderSizePixel = 0
        dot.Size = UDim2.new(0, 10, 0, 10)
        dot.Text = ""
        
        local dotCorner = Instance.new("UICorner")
        dotCorner.Parent = dot
        dotCorner.CornerRadius = UDim.new(1, 0)
        
        dot.MouseButton1Click:Connect(function()
            if index ~= currentPage then
                Pages[currentPage].Visible = false
                currentPage = index
                Pages[currentPage].Visible = true
                for i, d in ipairs(dots) do
                    d.BackgroundColor3 = i == currentPage and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(100, 100, 100)
                end
            end
        end)
        
        table.insert(dots, dot)
    end

    local function showPage(index)
        if index < 1 or index > totalPages then return end
        Pages[currentPage].Visible = false
        currentPage = index
        Pages[currentPage].Visible = true
        for i, d in ipairs(dots) do
            d.BackgroundColor3 = i == currentPage and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(100, 100, 100)
        end
    end

    local touchStart = nil
    PageContainer.InputBegan:Connect(function(input)
